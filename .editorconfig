root = true

[*]
indent_style = space
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
indent_size = 4

[*.{lua,toml,yaml,yml,fish}]
indent_size = 2

[Makefile]
indent_style = tab

# Markdown: trailing spaces can be significant (line breaks)
[*.md]
trim_trailing_whitespace = false
